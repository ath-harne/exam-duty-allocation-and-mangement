# ─────────────────────────────────────────────────────────────
# BACKEND environment variables
# Copy this file to .env for local development
# In production (Render), set these in the dashboard — never commit .env
# ─────────────────────────────────────────────────────────────

# Render injects PORT automatically. For local dev use 10000.
PORT=10000

# ── Database (choose ONE option) ──────────────────────────────

# Option A — Single connection URL (Railway / PlanetScale / any cloud MySQL)
# DATABASE_URL=mysql://user:password@host:port/dbname

# Option B — Individual credentials (local MySQL or Railway individual vars)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=exam_duty_management

# Set to true for any cloud database that requires SSL
DB_SSL=false

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
CLIENT_ORIGIN=http://localhost:5173,http://localhost:8080

# ─────────────────────────────────────────────────────────────
# FRONTEND environment variables (Vite — must be prefixed VITE_)
# In production set this in Render's frontend service env vars
# ─────────────────────────────────────────────────────────────

# Full URL to the backend API
VITE_API_BASE_URL=http://localhost:10000/api
